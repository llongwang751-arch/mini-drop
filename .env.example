# Mini-Drop local configuration example

# FastAPI / SQLAlchemy
DATABASE_URL=mysql+pymysql://minidrop:minidrop@mysql:3306/minidrop

# Docker Compose MySQL defaults
MYSQL_DATABASE=minidrop
MYSQL_USER=minidrop
MYSQL_PASSWORD=minidrop
MYSQL_ROOT_PASSWORD=minidrop-root

# Agent defaults
MINIDROP_AGENT_ID=local-agent
MINIDROP_SERVER_URL=http://server:8080

# Object storage. Use local for tests, minio for docker-compose.
OBJECT_STORAGE=minio
LOCAL_OBJECT_ROOT=data/objects
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minidrop
MINIO_SECRET_KEY=minidrop-secret
MINIO_BUCKET=minidrop
MINIO_SECURE=false

# Optional lightweight API auth. Leave empty in local demo mode.
MINIDROP_API_KEY=
